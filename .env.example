# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or Railway recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/transport_saas?sslmode=require"

# ─── Authentication (NextAuth.js) ────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional — remove if not using Google sign-in) ────────────````````````                                                                                                                                                                                                                 
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Socket.io ───────────────────────────────────────────────────────────────
# Leave empty for same-origin; set to external URL if using a separate WS server
NEXT_PUBLIC_SOCKET_URL=""

# ─── Billing / Invoicing ─────────────────────────────────────────────────────
# Default SaaS fee per active vehicle per month (in cents, e.g. 20000 = R200)
DEFAULT_TENANT_SAAS_FEE="20000"

# ─── File Uploads ────────────────────────────────────────────────────────────
# Local uploads are saved to public/uploads/ by default.
# For production, switch to S3/Cloudinary and set these:
# AWS_S3_BUCKET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="af-south-1"

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
# Secret used to authenticate Vercel Cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_MAILTO="mailto:admin@yourdomain.com"

# ─── App Config ──────────────────────────────────────────────────────────────
NODE_ENV="development"
